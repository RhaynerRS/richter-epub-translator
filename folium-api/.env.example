# Qual provedor de LLM usar: "ollama" (local), "deepseek" ou "openai" (nuvem).
# Nao inclui Claude/Anthropic: a lib epub-translator fala o protocolo de wire
# do OpenAI (openai.OpenAI client), e a API da Anthropic (Messages API) nao
# tem um endpoint OpenAI-compatible oficial - so da pra plugar aqui provedores
# que realmente implementam esse protocolo (default: openai)
LLM_PROVIDER=openai

# --- Credenciais/config genericas (mesmas vars pra qualquer provedor) ---
# Cada provedor tem defaults proprios pra BASE_URL e MODEL (ver adapters em
# config.py); so precisa setar aqui se quiser sobrescrever o default.

# Chave de API do provedor selecionado (obrigatoria, exceto no Ollama que
# aceita qualquer valor)
API_KEY=

# Endpoint do provedor (default depende do LLM_PROVIDER)
BASE_URL=

# Modelo do provedor (default depende do LLM_PROVIDER)
MODEL=

# --- Especifico do Ollama (usado apenas quando LLM_PROVIDER=ollama) ---

# Context window (num_ctx) passado ao Ollama por requisicao, em tokens.
# Truncado abaixo da janela nativa do modelo (32k) para deixar margem de
# seguranca (default: 30000)
OLLAMA_NUM_CTX=30000

# --- Comuns a qualquer provedor ---

# Tamanho maximo (em tokens de origem) de cada grupo de segmentos enviado
# por requisicao de traducao/fill. Grupos menores dao ao modelo menos
# elementos de bloco pra alinhar por vez, reduzindo erros estruturais em
# modelos menores. Modelos mais fortes (ex: OpenAI, DeepSeek) toleram
# valores maiores (default: 1000)
MAX_GROUP_TOKENS=1000

# Encoding tiktoken usado para estimar tokens ao agrupar segmentos (default: cl100k_base)
TOKEN_ENCODING=cl100k_base

# Diretorio onde os epubs enviados/traduzidos sao armazenados (default: ./data)
STORAGE_DIR=./data

# Numero de jobs de traducao que podem rodar em paralelo. Com um provedor
# em nuvem isso passa a ser limitado por rate limit da conta, nao por VRAM
# local (default: 4)
JOB_WORKERS=4

# Origens de frontend autorizadas a chamar a API via navegador (CORS), separadas
# por virgula (ex: https://app.meudominio.com,http://localhost:5173). Sem
# default: se vazia/ausente, nenhuma origem cross-origin e liberada (comportamento
# atual, sem CORS habilitado).
FRONTEND_ORIGIN=

# --- Login social (Google/GitHub) - cada provedor e opt-in separadamente ---
# GOOGLE_AUTH_ENABLED=true exige as credenciais GOOGLE_* abaixo; GITHUB_AUTH_ENABLED=true
# exige as credenciais GITHUB_* abaixo (falha no startup se faltar alguma das
# exigidas pelo provedor habilitado). Da pra habilitar so um dos dois. Se
# QUALQUER um dos dois estiver true, o app passa a exigir/verificar JWT nos
# endpoints de /translations e exige JWT_SECRET.
GOOGLE_AUTH_ENABLED=false
GITHUB_AUTH_ENABLED=false

# Client ID/secret do OAuth app do Google Cloud Console (obrigatorio se
# GOOGLE_AUTH_ENABLED=true)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redirect URI cadastrada no Google Cloud Console, deve bater exatamente
# (ex: http://localhost:8000/auth/google/callback) (obrigatorio se
# GOOGLE_AUTH_ENABLED=true)
GOOGLE_REDIRECT_URI=

# Client ID/secret do OAuth app do GitHub Developer Settings (obrigatorio se
# GITHUB_AUTH_ENABLED=true)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Redirect URI cadastrada no GitHub, deve bater exatamente
# (ex: http://localhost:8000/auth/github/callback) (obrigatorio se
# GITHUB_AUTH_ENABLED=true)
GITHUB_REDIRECT_URI=

# Segredo usado para assinar os JWTs emitidos pela API e o state do OAuth
# (obrigatorio se GOOGLE_AUTH_ENABLED=true ou GITHUB_AUTH_ENABLED=true, sem
# default - gere algo com pelo menos 32 bytes aleatorios, ex: openssl rand -hex 32)
JWT_SECRET=

# Algoritmo de assinatura do JWT (default: HS256)
JWT_ALGORITHM=HS256

# Validade do JWT emitido no login, em minutos (default: 10080 = 7 dias)
JWT_EXPIRES_MINUTES=10080

# Validade do state assinado usado no fluxo OAuth (CSRF), em segundos (default: 600)
OAUTH_STATE_TTL_SECONDS=600

# --- Cobranca via Stripe - opt-in (default: false) ---
# Quando true, exige GOOGLE_AUTH_ENABLED=true ou GITHUB_AUTH_ENABLED=true
# (falha no startup) + STRIPE_SECRET_KEY e STRIPE_WEBHOOK_SECRET abaixo.
PAYMENT_ENABLED=false

# Chave secreta da conta Stripe (test ou live). Obrigatoria se PAYMENT_ENABLED=true
STRIPE_SECRET_KEY=

# Segredo do endpoint de webhook (gerado por "stripe listen" em dev, ou pelo
# dashboard da Stripe em producao). Obrigatorio se PAYMENT_ENABLED=true
STRIPE_WEBHOOK_SECRET=

# Moeda usada nas cobrancas (default: usd)
STRIPE_CURRENCY=usd

# Preco por 1000 tokens estimados do epub, em centavos (default: 50 = US$0,50)
PRICE_PER_1K_TOKENS_CENTS=50

# Cobranca minima por traducao, em centavos, mesmo que a estimativa de tokens
# seja baixa (default: 50 = US$0,50)
MIN_CHARGE_CENTS=50

# URL publica desta API, usada para montar os links de retorno do Stripe
# Checkout (success_url/cancel_url) e do redirect OAuth (default: http://localhost:8000)
PUBLIC_BASE_URL=http://localhost:8000
